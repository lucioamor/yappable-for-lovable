{
  "manifest_version": 3,
  "name": "Yappable",
  "version": "0.1.0",
  "description": "Narrates completed Lovable agent responses via TTS — native browser speech or optional ElevenLabs.",
  "permissions": ["storage", "declarativeNetRequest"],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://api.elevenlabs.io/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "lovable_audio_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://lovable.dev/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://lovable.dev/*"],
      "js": ["src/risk-detector.js", "src/ir-builder.js", "src/renderer.js", "src/silence-monitor.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Yappable",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/single-sound-message-icq-ooh.mp3"],
      "matches": ["https://lovable.dev/*"]
    }
  ]
}
